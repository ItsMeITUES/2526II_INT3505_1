    {
      "name": "📚 Books – Read (Public)",
      "description": "GET endpoints — không cần token",
      "item": [

        {
          "name": "[GET] Get All Books – Default Pagination (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Response has books array and pagination', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('books');",
                  "    pm.expect(body.books).to.be.an('array');",
                  "    pm.expect(body).to.have.property('pagination');",
                  "});",
                  "",
                  "pm.test('Pagination object has correct keys', () => {",
                  "    const p = pm.response.json().pagination;",
                  "    pm.expect(p).to.have.all.keys(",
                  "        'Total Records', 'Total Pages', 'currentPage',",
                  "        'pageSize', 'hasNextPage', 'hasPreviousPage'",
                  "    );",
                  "});",
                  "",
                  "pm.test('Default pageSize is 10', () => {",
                  "    pm.expect(pm.response.json().pagination.pageSize).to.equal(10);",
                  "});",
                  "",
                  "pm.test('Cache-Control header present', () => {",
                  "    pm.expect(pm.response.headers.get('Cache-Control')).to.exist;",
                  "    pm.expect(pm.response.headers.get('Cache-Control')).to.include('max-age');",
                  "});",
                  "",
                  "pm.test('Response time < 500ms', () => {",
                  "    pm.expect(pm.response.responseTime).to.be.below(500);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVer}}/books",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVer}}", "books"]
            }
          }
        },

        {
          "name": "[GET] Get All Books – Custom Pagination (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Correct page and pageSize returned', () => {",
                  "    const p = pm.response.json().pagination;",
                  "    pm.expect(p.currentPage).to.equal(1);",
                  "    pm.expect(p.pageSize).to.equal(3);",
                  "});",
                  "",
                  "pm.test('Books array length <= pageSize', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.books.length).to.be.at.most(3);",
